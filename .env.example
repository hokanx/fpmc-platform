# FPMC Website — environment template.
# Copy to .env (git-ignored). Never commit real secrets.
#
# Email capture (double opt-in) — server-side vars, set in Vercel
# (Project Settings → Environment Variables). None are exposed to the browser.

# Brevo (brevo.com) — transactional confirmation mail + marketing list.
# The sender domain (hello@fpmc.house) must be verified in Brevo (SPF + DKIM) —
# branded sender only, never a sandbox sender.
BREVO_API_KEY=
BREVO_LIST_ID=

# HMAC secret for the stateless double-opt-in tokens. Generate: openssl rand -hex 32
LEADS_TOKEN_SECRET=

# Absolute origin used in the confirmation link (defaults to https://fpmc.house).
# SITE_URL=https://fpmc.house

# Branded sender address (defaults to hello@fpmc.house).
# LEADS_FROM_EMAIL=hello@fpmc.house

# Optional Supabase mirror (EU project) — the flow works Brevo-only without these;
# once set, signups upsert into public.leads and confirms fill confirmed_at.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Build-time feature flags (Vite; require a redeploy to change).
# VITE_FLAG_GIVEAWAY_TERMS=1   # /teilnahmebedingungen + /terms + footer links
